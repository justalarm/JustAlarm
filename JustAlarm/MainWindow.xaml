<Window x:Class="JustAlarm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⏰ Just Alarm" Height="340" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#000"
        Foreground="White"
        Icon="icon.ico"
        Closing="Window_Closing">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ClockText" Grid.Row="0"
                   HorizontalAlignment="Center"
                   FontSize="14" Foreground="#86868b" Margin="0,0,0,24"/>

        <TextBlock Grid.Row="1" Text="알람 시간 설정"
                   FontSize="20" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,24"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBox x:Name="HourBox" Width="60" Height="40"
                     Background="#1c1c1e" Foreground="White"
                     BorderBrush="#333" FontSize="18" TextAlignment="Center"
                     Text="12" VerticalContentAlignment="Center"/>
            <TextBlock Text=":" Foreground="White" FontSize="24"
                       VerticalAlignment="Center" Margin="8,0"/>
            <TextBox x:Name="MinBox" Width="60" Height="40"
                     Background="#1c1c1e" Foreground="White"
                     BorderBrush="#333" FontSize="18" TextAlignment="Center"
                     Text="00" VerticalContentAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                <RadioButton x:Name="AmBtn" Content="AM" GroupName="AmPm"
                             Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"
                             IsChecked="True">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Foreground" Value="#86868b"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
                <RadioButton x:Name="PmBtn" Content="PM" GroupName="AmPm"
                             FontSize="14" VerticalAlignment="Center">
                    <RadioButton.Style>
                        <Style TargetType="RadioButton">
                            <Setter Property="Foreground" Value="#86868b"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="RadioButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Style>
                </RadioButton>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="SetBtn" Content="✔  알람 설정"
                    Width="140" Height="40" Margin="0,0,12,0"
                    Background="#ff9f0a" Foreground="Black"
                    FontWeight="Bold" FontSize="14" BorderThickness="0"
                    Cursor="Hand" Click="SetBtn_Click"/>
            <Button x:Name="CancelBtn" Content="✖  취소"
                    Width="140" Height="40"
                    Background="#2c2c2e" Foreground="White"
                    FontWeight="Bold" FontSize="14" BorderThickness="0"
                    Cursor="Hand" Click="CancelBtn_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Grid.Row="4"
                   Text="알람이 설정되지 않았습니다."
                   HorizontalAlignment="Center"
                   Foreground="#86868b" FontSize="13"/>
    </Grid>
</Window>